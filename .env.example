

# KNOWS_API_KEY: Chinese OpenEvidence-like evidence search key for the news pipeline.
KNOWS_API_KEY="MY_KNOWS_API_KEY"

# KNOWS_BASE_URL: Base URL for the KNOWS evidence API.
KNOWS_BASE_URL="https://api.nullht.com"


# AnySearch web/news search (homepage news aggregator). The API key is OPTIONAL —
# anonymous access works with lower rate limits. Get a key at
# https://anysearch.com/console/api-keys for higher limits.
ANYSEARCH_API_KEY=""
# Override the AnySearch JSON-RPC endpoint if you self-host or proxy it.
# ANYSEARCH_ENDPOINT="https://api.anysearch.com/mcp"
# Set to 1 to disable the AnySearch web/news source in the news aggregator.
# NEWS_DISABLE_WEBSEARCH="0"

# Tavily news search (https://tavily.com - pancreatic cancer news)
TAVILY_API_KEY=""

# Google web search via Serper.dev (https://serper.dev)
SERPER_API_KEY=""

# Google Custom Search Engine (alternative to Serper)
# GOOGLE_API_KEY=""
# GOOGLE_CSE_ID=""

# Metaso / 秘塔 Chinese AI search (https://metaso.cn)
METASO_API_KEY=""

# Brave Search (https://brave.com/search/api/)
# BRAVE_API_KEY=""

# Exa neural search (https://exa.ai)
# EXA_API_KEY=""

# Disable specific search providers (set to "1" to disable)
# NEWS_DISABLE_TAVILY="0"
# NEWS_DISABLE_SERPER="0"
# NEWS_DISABLE_ANYSEARCH="0"
# NEWS_DISABLE_METASO="0"
# NEWS_DISABLE_BRAVE="0"
# NEWS_DISABLE_EXA="0"


# Server-side default LLM (OpenAI-compatible) for the personalized OSINTel routes
# (/api/personal/translate, /review, /assistant). Used when the client does not
# provide its own provider key. StepFun is OpenAI-compatible.
# STEP_API_KEY is accepted as an alias for LLM_API_KEY.
LLM_API_KEY="MY_OPENAI_COMPATIBLE_KEY"
LLM_BASE_URL="https://api.stepfun.com/v1"
LLM_MODEL="step-1-flash"
# LLM_PROVIDER defaults to openai_compatible; set to a registry id if needed.
# LLM_PROVIDER="openai_compatible"

# Local username/password auth (test-friendly). The default account always works;
# additional accounts can be created via the in-app registration form.
DEFAULT_USERNAME="admin"
DEFAULT_PASSWORD="pancreas123"
